<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.avc.infra.mapper.PublishRecordMapper">

    <select id="findByJobIdOrderByCreatedAtDesc" resultType="com.avc.infra.entity.PublishRecordEntity">
        SELECT * FROM publish_records WHERE job_id = #{jobId} ORDER BY created_at DESC
    </select>

    <select id="findByStatusOrderByCreatedAtDesc" resultType="com.avc.infra.entity.PublishRecordEntity">
        SELECT * FROM publish_records WHERE status = #{status} ORDER BY created_at DESC
    </select>

</mapper>
