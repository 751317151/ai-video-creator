<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.avc.infra.mapper.PlatformCredentialMapper">

    <select id="findByPlatformAndEnabledTrue" resultType="com.avc.infra.entity.PlatformCredentialEntity">
        SELECT * FROM platform_credentials WHERE platform = #{platform} AND enabled = true
    </select>

</mapper>
