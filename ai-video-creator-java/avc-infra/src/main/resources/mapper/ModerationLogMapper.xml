<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.avc.infra.mapper.ModerationLogMapper">

    <select id="selectPageOrdered" resultType="com.avc.infra.entity.ModerationLogEntity">
        SELECT * FROM moderation_log ORDER BY created_at DESC
    </select>

    <select id="selectByVerdictPaged" resultType="com.avc.infra.entity.ModerationLogEntity">
        SELECT * FROM moderation_log WHERE verdict = #{verdict} ORDER BY created_at DESC
    </select>

</mapper>
