# AI Video Creator - Python Worker Configuration
# Only MQ connection and working directory settings.
# All video-specific config (API keys, rendering params) is sent via MQ messages from Java.

# -- RocketMQ connection --
ROCKETMQ_NAMESRV=localhost:9876
MQ_CONSUMER_GROUP=avc-python-task-consumer-group
MQ_PRODUCER_GROUP=avc-python-producer-group
MQ_MAX_CONCURRENT_TASKS=2

# -- Health endpoint --
HEALTH_PORT=8081

# -- Working directories --
# OUTPUT_DIR=./output

# -- Logging --
DEBUG=false
LOG_LEVEL=INFO
